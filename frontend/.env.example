# URL backend Google Apps Script (link /exec hasil deploy web app).
# Contoh: https://script.google.com/macros/s/XXXXXXXX/exec
VITE_BACKEND_URL=

# Google OAuth 2.0 Client ID (Web application) dari Google Cloud Console.
# Harus sama dengan AuthController.CLIENT_ID di backend, dan origin dev/prod
# didaftarkan di "Authorized JavaScript origins".
VITE_GOOGLE_CLIENT_ID=
